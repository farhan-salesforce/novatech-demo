{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\\(now | strftime(\"%Y-%m-%dT%H:%M:%SZ\"))] Bash: \\(.tool_input.command)\"' >> \"$CLAUDE_PROJECT_DIR/.claude/logs/commands.log\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // \"\"'); if echo \"$file\" | grep -qE '\\.env$|\\.key$|secrets/'; then echo 'Blocked: Cannot modify sensitive files'; exit 2; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // \"\"'); if [[ \"$file\" =~ \\.(js|css|html)$ ]]; then npx prettier --write \"$file\" 2>/dev/null || true; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\\(now | strftime(\"%H:%M:%S\"))] \\(.tool_name): \\(.tool_input.file_path)\"' >> \"$CLAUDE_PROJECT_DIR\"/.claude/logs/file-changes.log",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tee -a \"$CLAUDE_PROJECT_DIR/.claude/logs/debug-notification.log\" | jq -r '\"[\\(now | strftime(\"%Y-%m-%dT%H:%M:%SZ\"))] \\(.)\"' >> \"$CLAUDE_PROJECT_DIR/.claude/logs/notifications.log\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tee -a \"$CLAUDE_PROJECT_DIR/.claude/logs/debug-stop.log\" | jq -r '\"[\\(now | strftime(\"%Y-%m-%dT%H:%M:%SZ\"))] Session ended: \\(.)\"' >> \"$CLAUDE_PROJECT_DIR/.claude/logs/sessions.log\"",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(git status)",
      "Bash(git diff:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Edit(*.env)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}

